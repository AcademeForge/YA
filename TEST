      <span class="rs-chip" style="background:var(--green-light);color:#16a34a;border-color:rgba(34,197,94,.2)">✅ ${correct} Correct</span>
      <span class="rs-chip" style="background:var(--red-light);color:#dc2626;border-color:rgba(239,68,68,.2)">❌ ${wrong} Wrong</span>
