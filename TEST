/* ═══════════════════════════════════════
   START QUIZ
═══════════════════════════════════════ */
function startQuizNx() {
  if (!_questions.length) { toast('No questions', 'Test has no questions.', 'error'); return; }
  _answers = {};
  _currentQ = 0;
  _quizActive = true;
  _timerSecs = 0;
  renderQuizNx();
  startTimerNx();
}

function startTimerNx() {
  clearInterval(_timerInterval);
  _timerSecs = 0;
  _timerInterval = setInterval(() => {
    _timerSecs++;
    updateTimerDisplayNx();
    if (_timerSecs >= _duration) {
      clearInterval(_timerInterval);
      toast('Time is up!', 'Auto-submitting your test.', 'warning', 3000);
      setTimeout(() => submitTestNx(), 1500);
    }
  }, 1000);
}

function updateTimerDisplayNx() {
  const remaining = _duration - _timerSecs;
  const el = document.getElementById('quizTimerBadgeNx');
  if (!el) return;
  el.textContent = `⏱ ${fmtTime(Math.max(0, remaining))}`;
  if (remaining <= 60) el.classList.add('urgent');
  else el.classList.remove('urgent');
}

function renderQuizNx() {
  const el = document.getElementById('testContentNx');
  const q = _questions[_currentQ];
  const total = _questions.length;
  const answered = Object.keys(_answers).length;
  const pct = Math.round((_currentQ / total) * 100);

  el.innerHTML = `
    <div class="quiz-header">
      <div class="quiz-progress-wrap">
        <div class="quiz-prog-top">
          <span class="quiz-prog-label">Q${_currentQ+1} / ${total}</span>
          <span id="quizTimerBadgeNx" class="quiz-timer-badge">⏱ ${fmtTime(_duration)}</span>
        </div>
        <div class="quiz-prog-bar"><div class="quiz-prog-fill" style="width:${pct}%"></div></div>
      </div>
      <button class="icon-btn" onclick="openModalNx('exitTestModal')" style="flex-shrink:0">✕</button>
    </div>

    <div class="section-title" style="margin-top:0">Question Overview</div>
    <div class="q-overview" id="qOverviewNx">${_questions.map((qq, i) => {
      let cls = '';
      if (i === _currentQ) cls = 'current';
      else if (_answers[qq.id]) cls = 'answered';
      return `<div class="q-dot ${cls}" onclick="goToQNx(${i})">${i+1}</div>`;
    }).join('')}</div>

    <div class="question-card">
      <div class="q-num">Question ${_currentQ + 1} of ${total}</div>
      <div class="q-text">${q.question}</div>
    </div>

    <div class="options-list">
      ${['A','B','C','D'].filter((_, i) => q[`option_${['a','b','c','d'][i]}`]).map((letter, i) => {
        const optKey = `option_${letter.toLowerCase()}`;
        const isSelected = _answers[q.id] === letter;
        return `<button class="option-btn ${isSelected ? 'selected' : ''}" onclick="selectAnswerNx('${q.id}','${letter}')">
          <div class="opt-letter">${letter}</div>
          <div class="opt-text">${q[optKey]}</div>
        </button>`;
      }).join('')}
    </div>

    <div class="quiz-nav">
      ${_currentQ > 0 ? `<button class="btn btn-secondary" onclick="goToQNx(${_currentQ-1})">← Prev</button>` : '<div></div>'}
      ${_currentQ < total - 1 ? `<button class="btn btn-primary" onclick="goToQNx(${_currentQ+1})">Next →</button>` : '<div></div>'}
    </div>

    <button class="submit-btn" onclick="confirmSubmitNx()" ${answered < 1 ? 'disabled' : ''}>
      ✅ Submit Test (${answered}/${total} answered)
    </button>
  `;

  updateTimerDisplayNx();
}

function goToQNx(idx) {
  _currentQ = idx;
  renderQuizNx();
  // restore timer display
  updateTimerDisplayNx();
}

function selectAnswerNx(qId, letter) {
  _answers[qId] = letter;
  renderQuizNx();
}

function confirmSubmitNx() {
  const answered = Object.keys(_answers).length;
  const total = _questions.length;
  document.getElementById('confirmSubmitMsgNx').textContent = `You've answered ${answered} of ${total} questions.`;
  const warn = document.getElementById('confirmSubmitWarnNx');
  if (answered < total) {
    warn.style.display = 'block';
    warn.textContent = `⚠️ ${total - answered} question${total - answered > 1 ? 's' : ''} unanswered — they will be marked incorrect.`;
  } else {
    warn.style.display = 'none';
  }
  openModalNx('confirmSubmitModal');
}

async function submitTestNx() {
  closeModalNx('confirmSubmitModal');
  clearInterval(_timerInterval);
  _quizActive = false;

  const el = document.getElementById('testContentNx');
  el.innerHTML = '<div class="empty-state"><div class="spin" style="margin:0 auto 12px"></div><p>Submitting your test…</p></div>';

  const answerArray = _questions.map(q => ({ question_id: q.id, selected_option: _answers[q.id] || '' }));

  try {
    const res = await api('submit-test', {
      test_id: _test.test.id,
      answers: answerArray,
      time_taken_seconds: _timerSecs
    });

    if (!res.ok) {
      if (res.already_attempted) {
        toast('Already Submitted', res.message, 'warning', 5000);
        _test.already_attempted = true;
        _test.attempt = res.attempt;
        renderTestScreenNx();
        return;
      }
      toast('Submission Failed', res.message, 'error');
      renderQuizNx(); // restore quiz
      _quizActive = true;
      startTimerNx();
      return;
    }

    // Success
    const r = res.result;
    const cls = scoreClass(r.score, r.total_questions);

    document.getElementById('resultIconNx').textContent = r.score / r.total_questions >= 0.7 ? '🎉' : '📋';
    document.getElementById('resultTitleNx').textContent = r.score / r.total_questions >= 0.7 ? 'Well Done!' : 'Test Submitted!';
    document.getElementById('resultMsgNx').textContent = `${r.remark} · Rank #${r.rank} of ${r.total_attempts} students`;
    document.getElementById('resultBreakdownNx').innerHTML = `
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px">
        <div style="text-align:center"><div style="font-family:var(--font-mono);font-size:1.2rem;font-weight:700;color:${scoreColor(r.score, r.total_questions)}">${r.score}/${r.total_questions}</div><div style="font-size:.62rem;color:var(--text-muted);text-transform:uppercase;margin-top:2px">Score</div></div>
        <div style="text-align:center"><div style="font-family:var(--font-mono);font-size:1.2rem;font-weight:700;color:var(--primary)">#${r.rank}</div><div style="font-size:.62rem;color:var(--text-muted);text-transform:uppercase;margin-top:2px">Rank</div></div>
        <div style="text-align:center"><div style="font-family:var(--font-mono);font-size:1.2rem;font-weight:700">${fmtTime(r.time_taken_seconds||0)}</div><div style="font-size:.62rem;color:var(--text-muted);text-transform:uppercase;margin-top:2px">Time</div></div>
      </div>`;
    openModalNx('resultModal');

    // Update state & refresh
    _test.already_attempted = true;
    _test.attempt = r;
    renderTestScreenNx();
    _dashData = null;
    fullRefreshNx(true);

  } catch(e) {
    toast('Network Error', 'Check connection and try again.', 'error');
    renderQuizNx();
    _quizActive = true;
    startTimerNx();
  }
}

