      </div>
      <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:12px">
        <span style="padding:4px 10px;border-radius:999px;font-size:.68rem;font-weight:700;background:var(--primary-light);color:var(--primary);border:1px solid var(--border)">${h.my_remark}</span>
        <span style="padding:4px 10px;border-radius:999px;font-size:.68rem;font-weight:700;background:var(--surface-3);color:var(--text-soft);border:1px solid var(--border)">⏱ ${fmtTime(h.my_time_taken_seconds||0)}</span>
        <span style="padding:4px 10px;border-radius:999px;font-size:.68rem;font-weight:700;background:var(--surface-3);color:var(--text-soft);border:1px solid var(--border)">Avg: ${h.average_mark}/${h.total_questions}</span>
      </div>
      ${top10Html ? `<div class="lb-title">🏆 Top Students</div>${top10Html}` : ''}
    </div>`;
  }).join('');
}

/* ═══════════════════════════════════════
   FULL REFRESH
═══════════════════════════════════════ */
async function fullRefreshNx(silent = false) {
  if (!silent) toast('Refreshing…', '', 'info', 2000);
  _dashData = null;
  _test = null;
  _loadedScreens.clear();

  try {
    // parallel fetch
    const [dashRes, testRes] = await Promise.all([
      api('dashboard').catch(() => null),
      api('load-test').catch(() => null)
    ]);
    _dashData = dashRes;
    _test = testRes;
    _loadedScreens.add('test');

    renderHomeNx();

    const activeScreen = document.querySelector('.screen.active')?.id;
    if (activeScreen === 'testScreen') renderTestScreenNx();
    if (activeScreen === 'historyScreen') { _loadedScreens.delete('history'); loadHistoryScreenNx(); }

    if (!silent) toast('Updated!', '', 'success', 2000);
  } catch(e) {
    if (!silent) toast('Refresh failed', 'Check connection.', 'error');
  }
}

/* ═══════════════════════════════════════
   PROTECTION
═══════════════════════════════════════ */
document.addEventListener("contextmenu", e => e.preventDefault());
document.addEventListener("keydown", e => {
  if (e.key==="F12"||(e.ctrlKey&&e.shiftKey&&["i","j","c"].includes(e.key.toLowerCase()))||(e.ctrlKey&&["u","s"].includes(e.key.toLowerCase()))) e.preventDefault();
});
document.addEventListener("selectstart", e => { if (_quizActive) e.preventDefault(); });
document.addEventListener("copy", e => { if (_quizActive) e.preventDefault(); });

/* Tab visibility — pause timer when hidden */
document.addEventListener('visibilitychange', () => {
  if (_quizActive && document.hidden) toast('Warning', 'Do not switch tabs during the test!', 'warning', 4000);
});

/* Storage event — detect AF login */
window.addEventListener('storage', e => {
  const afKeys = ['af_student_name','af_student_mobile','af_student_email','af_student_logged_in','af_student_id','af_student_uuid'];
  if (afKeys.includes(e.key)) {
    refreshSettingsBarNx();
    renderHomeNx();
    const af = getAF();
    if (af.loggedIn && af.studentId) fullRefreshNx(true);
  }
});

/* ═══════════════════════════════════════
   INIT
═══════════════════════════════════════ */
async function initNx() {
  loadThemeNx();
  refreshSettingsBarNx();

  const af = getAF();
  if (af.loggedIn && af.name) {
    setTimeout(() => toast(`Welcome back, ${af.name.split(' ')[0]}! 👋`, 'Syncing your test data…', 'success', 3000), 400);
  }

  // Show skeleton home immediately
  renderHomeNx();

  // Prefetch everything in parallel
  try {
    const [dashRes, testRes] = await Promise.all([
      api('dashboard').catch(() => null),
      api('load-test').catch(() => null)
    ]);
    _dashData = dashRes;
    _test = testRes;
    _loadedScreens.add('test');
    renderHomeNx();
  } catch(e) {
    console.warn('Prefetch failed:', e);
  }
}

initNx();
</script>
