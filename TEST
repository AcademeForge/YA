<script>
/* ═══════════════════════════════════════
   API
═══════════════════════════════════════ */
const API = "https://afooyyydhlwngzssgqih.supabase.co/functions/v1/student-test-af";

/* ═══════════════════════════════════════
   STATE
═══════════════════════════════════════ */
let _test       = null; // current test meta
let _questions  = [];   // questions for active test
let _answers    = {};   // {questionId: selectedOption}
let _currentQ   = 0;
let _timerSecs  = 0;
let _timerInterval = null;
let _duration   = 600;
let _quizActive = false;
let _dashData   = null; // prefetched dashboard
let _reviewData = null;
let _loadedScreens = new Set();

/* ═══════════════════════════════════════
   AF STUDENT
═══════════════════════════════════════ */
function getAF() {
  return {
    name:      localStorage.getItem('af_student_name')       || '',
    phone:     localStorage.getItem('af_student_mobile')     || localStorage.getItem('af_student_phone') || '',
    email:     localStorage.getItem('af_student_email')      || '',
    studentId: localStorage.getItem('af_student_id')         || '',
    uuid:      localStorage.getItem('af_student_uuid')       || '',
    loggedIn:  localStorage.getItem('af_student_logged_in')  === 'true'
  };
}

/* ═══════════════════════════════════════
   API HELPER
═══════════════════════════════════════ */
async function api(action, extra = {}) {
  const af = getAF();
  const body = { action, student_id: af.studentId, student_name: af.name, student_mobile: af.phone, student_email: af.email, student_uuid: af.uuid, ...extra };
  const res = await fetch(API, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
  const data = await res.json();
  return data;
}

/* ═══════════════════════════════════════
   TOAST
═══════════════════════════════════════ */
function toast(title, msg = '', type = 'info', dur = 3500) {
  const icons = { success: '✅', error: '❌', warning: '⚠️', info: 'ℹ️' };
  const wrap = document.getElementById('toastWrap');
  const el = document.createElement('div');
  el.className = `toast ${type}`;
  el.innerHTML = `<div class="toast-icon">${icons[type]}</div>
    <div class="toast-body"><div class="toast-title">${title}</div>${msg ? `<div class="toast-msg">${msg}</div>` : ''}</div>
    <button class="toast-close" onclick="this.parentElement.remove()">✕</button>`;
  wrap.appendChild(el);
  setTimeout(() => { el.classList.add('out'); setTimeout(() => el.remove(), 220); }, dur);
}

/* ═══════════════════════════════════════
   MODAL
═══════════════════════════════════════ */
function openModalNx(id) { document.getElementById(id).classList.add('show'); }
function closeModalNx(id) { document.getElementById(id).classList.remove('show'); }
document.querySelectorAll('.modal').forEach(m => m.addEventListener('click', e => { if (e.target === m) m.classList.remove('show'); }));

/* ═══════════════════════════════════════
   SCREEN NAV
═══════════════════════════════════════ */
function openScreenNx(id) {
  if (_quizActive && id !== 'testScreen') {
    openModalNx('exitTestModal');
    return;
  }
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  const btn = document.querySelector(`.nav-btn[data-screen="${id}"]`);
  if (btn) btn.classList.add('active');

  if (id === 'historyScreen' && !_loadedScreens.has('history')) loadHistoryScreenNx();
  if (id === 'testScreen' && !_loadedScreens.has('test')) loadTestScreenNx();
  document.getElementById('headerSubNx').textContent = { homeScreen: 'Test Portal', testScreen: 'Active Test', reviewScreen: 'Review', historyScreen: 'History', settingsScreen: 'Settings' }[id] || 'AF Test';
}

function openReviewScreenNx() {
  openScreenNx('reviewScreen');
  loadReviewScreenNx();
}

function exitTestNx() {
  _quizActive = false;
  clearInterval(_timerInterval);
  openScreenNx('homeScreen');
}

/* ═══════════════════════════════════════
   THEME
═══════════════════════════════════════ */
function loadThemeNx() {
  const dark = localStorage.getItem('af_test_theme') === 'dark';
  document.body.classList.toggle('dark', dark);
  document.getElementById('darkToggleNx').classList.toggle('on', dark);
  document.getElementById('darkBtnNx').textContent = dark ? '☀️' : '🌙';
}
function toggleThemeNx() {
  document.body.classList.toggle('dark');
  const dark = document.body.classList.contains('dark');
  localStorage.setItem('af_test_theme', dark ? 'dark' : 'light');
  document.getElementById('darkToggleNx').classList.toggle('on', dark);
  document.getElementById('darkBtnNx').textContent = dark ? '☀️' : '🌙';
}

/* ═══════════════════════════════════════
   HELPERS
═══════════════════════════════════════ */
function fmtTime(secs) {
  const m = Math.floor(secs / 60), s = secs % 60;
  return `${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
}
function scoreClass(score, total) {
  const pct = total ? (score / total) * 100 : 0;
  if (pct >= 80) return 'great';
  if (pct >= 60) return 'good';
  if (pct >= 40) return 'ok';
  return 'poor';
}
function scoreColor(score, total) {
  const c = scoreClass(score, total);
  return { great: 'var(--green)', good: 'var(--primary)', ok: 'var(--accent)', poor: 'var(--red)' }[c];
}
function medal(rank) {
  if (rank === 1) return '🥇';
  if (rank === 2) return '🥈';
  if (rank === 3) return '🥉';
  return `#${rank}`;
}

